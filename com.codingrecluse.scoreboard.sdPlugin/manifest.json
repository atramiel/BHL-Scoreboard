{
  "Author": "George Carr",
  "CodePath": "bin/plugin.js",
  "Description": "Control the Scoreboard app from your Stream Deck",
  "Icon": "imgs/plugin",
  "Name": "BHL Scoreboard",
  "Category": "BHL Scoreboard",
  "CategoryIcon": "imgs/plugin",
  "UUID": "com.codingrecluse.scoreboard",
  "Version": "1.0.0",
  "SDKVersion": 2,
  "Nodejs": {
    "Version": "20",
    "Debug": "enabled"
  },
  "Software": {
    "MinimumVersion": "6.4"
  },
  "OS": [
    {
      "Platform": "windows",
      "MinimumVersion": "10"
    }
  ],
  "Profiles": [
    {
      "Name": "Bot Hockey",
      "DeviceType": 7,
      "File": "profiles/Bot Hockey.streamDeckProfile",
      "ReadOnly": false,
      "DontAutoSwitchWhenInstalled": false
    }
  ],
  "Actions": [
    {
      "Name": "Score Home",
      "UUID": "com.codingrecluse.scoreboard.scorehome",
      "Icon": "imgs/actions/scorehome/icon",
      "States": [{ "Image": "imgs/actions/scorehome/icon" }]
    },
    {
      "Name": "Score Away",
      "UUID": "com.codingrecluse.scoreboard.scoreaway",
      "Icon": "imgs/actions/scoreaway/icon",
      "States": [{ "Image": "imgs/actions/scoreaway/icon" }]
    },
    {
      "Name": "Penalty Home",
      "UUID": "com.codingrecluse.scoreboard.penaltyhome",
      "Icon": "imgs/actions/penaltyhome/icon",
      "States": [{ "Image": "imgs/actions/penaltyhome/icon" }]
    },
    {
      "Name": "Penalty Away",
      "UUID": "com.codingrecluse.scoreboard.penaltyaway",
      "Icon": "imgs/actions/penaltyaway/icon",
      "States": [{ "Image": "imgs/actions/penaltyaway/icon" }]
    },
    {
      "Name": "Play / Pause",
      "UUID": "com.codingrecluse.scoreboard.playpause",
      "Icon": "imgs/actions/playpause/icon",
      "States": [{ "Image": "imgs/actions/playpause/icon" }]
    },
    {
      "Name": "Reset Game",
      "UUID": "com.codingrecluse.scoreboard.reset",
      "Icon": "imgs/actions/reset/icon",
      "States": [{ "Image": "imgs/actions/reset/icon" }]
    },
    {
      "Name": "Undo",
      "UUID": "com.codingrecluse.scoreboard.undo",
      "Icon": "imgs/actions/undo/icon",
      "States": [{ "Image": "imgs/actions/undo/icon" }]
    },
    {
      "Name": "Redo",
      "UUID": "com.codingrecluse.scoreboard.redo",
      "Icon": "imgs/actions/redo/icon",
      "States": [{ "Image": "imgs/actions/redo/icon" }]
    },
    {
      "Name": "Swap Sides",
      "UUID": "com.codingrecluse.scoreboard.swapsides",
      "Icon": "imgs/actions/swapsides/icon",
      "States": [{ "Image": "imgs/actions/swapsides/icon" }]
    },
    {
      "Name": "Reset Clock",
      "UUID": "com.codingrecluse.scoreboard.resetclock",
      "Icon": "imgs/actions/resetclock/icon",
      "States": [{ "Image": "imgs/actions/resetclock/icon" }]
    },
    {
      "Name": "Between Game",
      "UUID": "com.codingrecluse.scoreboard.betweengame",
      "Icon": "imgs/plugin",
      "States": [{ "Image": "imgs/plugin" }]
    },
    {
      "Name": "Match Slot 1",
      "UUID": "com.codingrecluse.scoreboard.matchslot1",
      "Icon": "imgs/matchslot",
      "States": [{ "Image": "imgs/matchslot" }]
    },
    {
      "Name": "Match Slot 2",
      "UUID": "com.codingrecluse.scoreboard.matchslot2",
      "Icon": "imgs/matchslot",
      "States": [{ "Image": "imgs/matchslot" }]
    },
    {
      "Name": "Match Slot 3",
      "UUID": "com.codingrecluse.scoreboard.matchslot3",
      "Icon": "imgs/matchslot",
      "States": [{ "Image": "imgs/matchslot" }]
    },
    {
      "Name": "Match Slot 4",
      "UUID": "com.codingrecluse.scoreboard.matchslot4",
      "Icon": "imgs/matchslot",
      "States": [{ "Image": "imgs/matchslot" }]
    },
    {
      "Name": "Match Slot 5",
      "UUID": "com.codingrecluse.scoreboard.matchslot5",
      "Icon": "imgs/matchslot",
      "States": [{ "Image": "imgs/matchslot" }]
    },
    {
      "Name": "Match Slot 6",
      "UUID": "com.codingrecluse.scoreboard.matchslot6",
      "Icon": "imgs/matchslot",
      "States": [{ "Image": "imgs/matchslot" }]
    },
    {
      "Name": "Next Match Timer",
      "UUID": "com.codingrecluse.scoreboard.nextmatch",
      "Icon": "imgs/plugin",
      "States": [{ "Image": "imgs/plugin" }],
      "Controllers": ["Encoder"],
      "Encoder": {
        "layout": "$B1",
        "TriggerDescription": {
          "Rotate": "Adjust time",
          "Push": "Start countdown"
        }
      }
    }
  ]
}
