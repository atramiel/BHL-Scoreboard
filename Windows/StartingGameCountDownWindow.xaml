<Window x:Class="Scoreboard.Windows.StartingGameCountDownWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Scoreboard.ViewModels"
        xmlns:h="clr-namespace:Scoreboard.Helpers"
        mc:Ignorable="d"
        Topmost="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        Icon="../Resources/appIcon.ico"
        ResizeMode="NoResize"
        Title="StartingGameCountDownWindow" Height="450" Width="800">
    <Window.DataContext>
        <local:StartingGameCountDownViewModel />
    </Window.DataContext>
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding StartCountDownCommand}" />
        </i:EventTrigger>
    </i:Interaction.Triggers>
    <Border  BorderBrush="Black"
             BorderThickness="20"
             Background="Transparent"
             CornerRadius="20">
        <i:Interaction.Triggers>
            <i:DataTrigger Binding="{Binding IsAlternateColor}"
                           Value="True">
                <i:ChangePropertyAction PropertyName="Background"
                                        Value="LightBlue" />
            </i:DataTrigger>
            <i:DataTrigger Binding="{Binding IsAlternateColor}"
                           Value="False">
                <i:ChangePropertyAction PropertyName="Background"
                                        Value="OrangeRed" />
            </i:DataTrigger>
        </i:Interaction.Triggers>
        <Label HorizontalAlignment="Stretch"
               VerticalAlignment="Stretch"
               Background="Transparent"
               Style="{StaticResource LargeLabel}">
            <Binding Path="Clock">
                <Binding.Converter>
                    <h:TimeSpanConverter />
                </Binding.Converter>
            </Binding>
        </Label>
    </Border>
</Window>
