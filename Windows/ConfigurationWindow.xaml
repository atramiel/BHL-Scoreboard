<Window x:Class="Scoreboard.Windows.ConfigurationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Scoreboard.Windows"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:vm="clr-namespace:Scoreboard.ViewModels"
        xmlns:enums="clr-namespace:Scoreboard.Enums"
        mc:Ignorable="d"
        WindowStartupLocation="CenterOwner"
        SizeToContent="WidthAndHeight"
        x:Name="SettingsWindow"
        Title="{Binding Title}"
        Icon="../Resources/appIcon.ico"
        MinHeight="275"
        MinWidth="500"
        MaxWidth="700">
    <Window.DataContext>
        <vm:ConfigurationViewModel />
    </Window.DataContext>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <i:Interaction.Triggers>
            <i:EventTrigger EventName="Loaded">
                <i:InvokeCommandAction Command="{Binding LoadCommand}" />
            </i:EventTrigger>
        </i:Interaction.Triggers>
        <Grid Grid.Column="0"
              Margin="16"
              VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <StackPanel Orientation="Horizontal"
                        Grid.Row="0"
                        Grid.Column="0">
                <Border Height="16"
                        Width="16"
                        BorderThickness="1"
                        BorderBrush="Black"
                        Background="{Binding HomeDisplayColor, FallbackValue=Green}"
                        CornerRadius="5">
                    <i:Interaction.Triggers>
                        <i:EventTrigger EventName="MouseDown">
                            <i:InvokeCommandAction Command="{Binding HomeColorCommand}" />
                        </i:EventTrigger>
                    </i:Interaction.Triggers>
                </Border>
                <Label Content="Home Team:"
                       VerticalAlignment="Center" />
            </StackPanel>
            <TextBox Text="{Binding Settings.HomeTeamName}"
                     HorizontalAlignment="Stretch"
                     VerticalAlignment="Center"
                     Grid.Row="0"
                     Grid.Column="1" />

            <StackPanel Orientation="Horizontal"
                        Grid.Row="1"
                        Grid.Column="0">
                <Border Height="16"
                        Width="16"
                        BorderThickness="1"
                        BorderBrush="Black"
                        Background="{Binding VisitorDisplayColor, FallbackValue=Brown}"
                        CornerRadius="5">
                    <i:Interaction.Triggers>
                        <i:EventTrigger EventName="MouseDown">
                            <i:InvokeCommandAction Command="{Binding VisitorColorCommand}" />
                        </i:EventTrigger>
                    </i:Interaction.Triggers>
                </Border>
                <Label Content="Visitor Team:"
                       VerticalAlignment="Center" />
            </StackPanel>
            <TextBox Text="{Binding Settings.VisitorTeamName}"
                     HorizontalAlignment="Stretch"
                     VerticalAlignment="Center"
                     Grid.Row="1"
                     Grid.Column="1" />

            <Label Content="Game Minutes:"
                   Grid.Row="2"
                   Grid.Column="0"
                   VerticalAlignment="Center" />
            <TextBox Text="{Binding Settings.GameLengthMinutes}"
                     HorizontalAlignment="Stretch"
                     VerticalAlignment="Center"
                     Grid.Row="2"
                     Grid.Column="1" />

            <Label Content="Penalty Minutes:"
                   Grid.Row="3"
                   Grid.Column="0"
                   VerticalAlignment="Center" />
            <TextBox Text="{Binding Settings.PenaltyLengthMinutes}"
                     HorizontalAlignment="Stretch"
                     VerticalAlignment="Center"
                     Grid.Row="3"
                     Grid.Column="1" />

            <StackPanel Orientation="Horizontal"
                        Grid.Row="4"
                        Grid.Column="0">
                <Button Command="{Binding EditLedEffectCommand}"
                        Width="16"
                        Height="16"
                        Margin="5">
                    <Image Source="../Resources/lightbulb.png" />
                </Button>
                <Label Content="SignalRGB FilePath"
                       VerticalAlignment="Center" />
            </StackPanel>
            <TextBox Text="{Binding Settings.LedAddress}"
                     HorizontalAlignment="Stretch"
                     VerticalAlignment="Center"
                     Grid.Row="4"
                     Grid.Column="1" />

            <Label Content="Bracket URL:"
                   Grid.Row="5"
                   Grid.Column="0"
                   VerticalAlignment="Center" />
            <TextBox Text="{Binding Settings.BracketUrl}"
                     HorizontalAlignment="Stretch"
                     VerticalAlignment="Center"
                     Grid.Row="5"
                     Grid.Column="1" />

            <Label Content="Learn More URL:"
                   Grid.Row="6"
                   Grid.Column="0"
                   VerticalAlignment="Center" />
            <TextBox Text="{Binding Settings.LearnMoreUrl}"
                     HorizontalAlignment="Stretch"
                     VerticalAlignment="Center"
                     Grid.Row="6"
                     Grid.Column="1" />

            <StackPanel Orientation="Horizontal"
                        Grid.Row="7"
                        Grid.Column="1"
                        HorizontalAlignment="Right">
                <CheckBox IsChecked="{Binding Settings.SoundEnabled}"
                          Content="Sound"
                          VerticalAlignment="Center"
                          Margin="5"/>
                <CheckBox IsChecked="{Binding Settings.IsKioskMode}"
                          Content="Kiosk Mode"
                          VerticalAlignment="Center"
                          Margin="5"/>
                <Button Content="Save"
                        Width="45"
                        Margin="5"
                        Command="{Binding SaveCommand}" />
                <Button Content="Cancel"
                        Width="45"
                        Margin="5"
                        IsCancel="True"
                        Command="{Binding CancelCommand}" />
            </StackPanel>

        </Grid>
        <ListBox ItemsSource="{Binding KeyBindings}"
                 Grid.Column="1"
                 Focusable="False">
            <ListBox.ItemTemplate>
                <HierarchicalDataTemplate>
                    <Grid HorizontalAlignment="Stretch">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal"
                                    Grid.Column="0">
                            <Label Content="{Binding Key}" />
                            <Label Content=":" />
                            <Label Content="{Binding Value}" />
                        </StackPanel>
                        <Button Grid.Column="1"
                                HorizontalAlignment="Right"
                                Content="Set"
                                Command="{Binding ElementName=SettingsWindow, Path=DataContext.SetKeyCommand}"
                                CommandParameter="{Binding Key}" />
                    </Grid>
                </HierarchicalDataTemplate>
            </ListBox.ItemTemplate>
            <i:Interaction.Triggers>
                <i:EventTrigger EventName="PreviewKeyDown">
                    <i:InvokeCommandAction Command="{Binding InputCommand}"
                                           PassEventArgsToCommand="True" />
                </i:EventTrigger>
            </i:Interaction.Triggers>
        </ListBox>
        <Border Background="#7affffff"
                BorderThickness="1"
                VerticalAlignment="Center"
                BorderBrush="black"
                Grid.Column="1"
                Height="64">
            <TextBlock Text="Press New Key"
                       FontWeight="Bold"
                       TextAlignment="Center"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontSize="18"
                       TextWrapping="Wrap"
                       Opacity="1" />
            <i:Interaction.Triggers>
                <i:DataTrigger Binding="{Binding ShowKeypressPrompt}"
                               Value="False">
                    <i:ChangePropertyAction PropertyName="Visibility"
                                            Value="Hidden" />
                </i:DataTrigger>
                <i:DataTrigger Binding="{Binding ShowKeypressPrompt}"
                               Value="True">
                    <i:ChangePropertyAction PropertyName="Visibility"
                                            Value="Visible" />
                </i:DataTrigger>
            </i:Interaction.Triggers>
        </Border>
        <Border Background="#7aff0000"
                VerticalAlignment="Center"
                BorderBrush="black"
                BorderThickness="1"
                Grid.Column="1"
                Height="Auto">
            <DockPanel FlowDirection="RightToLeft">
                <Button Content="X"
                        Height="25"
                        Width="25"
                        Margin="2"
                        VerticalContentAlignment="Center"
                        HorizontalAlignment="Right"
                        Command="{Binding DismissError}" />
                <TextBlock Text="{Binding ErrorMessage, FallbackValue='Sample error message.'}"
                           FontWeight="Bold"
                           FontSize="18"
                           TextAlignment="Center"
                           FlowDirection="LeftToRight"
                           HorizontalAlignment="Stretch"
                           Width="Auto"
                           MaxWidth="200"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap"
                           Opacity="1" />
            </DockPanel>
            <i:Interaction.Triggers>
                <i:DataTrigger Binding="{Binding ShowError}"
                               Value="False">
                    <i:ChangePropertyAction PropertyName="Visibility"
                                            Value="Hidden" />
                </i:DataTrigger>
                <i:DataTrigger Binding="{Binding ShowError}"
                               Value="True">
                    <i:ChangePropertyAction PropertyName="Visibility"
                                            Value="Visible" />
                </i:DataTrigger>
            </i:Interaction.Triggers>
        </Border>
    </Grid>
</Window>
