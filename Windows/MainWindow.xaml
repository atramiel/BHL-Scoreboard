<Window x:Class="Scoreboard.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Scoreboard.ViewModels"
        xmlns:h="clr-namespace:Scoreboard.Helpers"
        mc:Ignorable="d"
        Title="MainWindow"
        Height="1000"
        Width="800"
        Focusable="True"
        Topmost="{Binding IsFocusLocked}"
        WindowStyle="SingleBorderWindow"
        WindowStartupLocation="CenterScreen"
        WindowState="Normal"
        Icon="../Resources/appIcon.ico"
        ResizeMode="CanResize">
    <Window.Resources>
        <ResourceDictionary>
            <ScaleTransform x:Key="Mirror"
                            ScaleX="-1" />
            <ScaleTransform x:Key="Normal"
                            ScaleX="1" />
        </ResourceDictionary>
    </Window.Resources>
    <!--<Window.Background>
        <ImageBrush ImageSource="../Resources/hockeyRinkGray.png" />
    </Window.Background>-->

    <i:Interaction.Triggers>
        <!--<i:DataTrigger Binding="{Binding ClockWithinThirtySeconds}"
                       Value="True">
            <i:InvokeCommandAction Command="{Binding BlinkMediumCommand}" />
        </i:DataTrigger>
        <i:DataTrigger Binding="{Binding FinalTenSeconds}"
                       Value="True">
            <i:InvokeCommandAction Command="{Binding BlinkFastCommand}" />
        </i:DataTrigger>
        <i:DataTrigger Binding="{Binding ClockWithinMinute}"
                       Value="True">
            <i:InvokeCommandAction Command="{Binding BlinkSlowCommand}" />
        </i:DataTrigger>-->
        <i:DataTrigger Binding="{Binding IsFocusLocked}"
                       Value="True">
            <i:ChangePropertyAction PropertyName="WindowStyle"
                                    Value="None" />
        </i:DataTrigger>
        <i:DataTrigger Binding="{Binding IsFocusLocked}"
                       Value="False">
            <i:ChangePropertyAction PropertyName="WindowStyle"
                                    Value="SingleBorderWindow" />
        </i:DataTrigger>
        <i:DataTrigger Binding="{Binding IsFocusLocked}"
                       Value="True">
            <i:ChangePropertyAction PropertyName="WindowState"
                                    Value="Maximized" />
        </i:DataTrigger>
        <i:DataTrigger Binding="{Binding IsFocusLocked}"
                       Value="True">
            <i:ChangePropertyAction PropertyName="ResizeMode"
                                    Value="NoResize" />
        </i:DataTrigger>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding LoadCommand}" />
        </i:EventTrigger>
        <i:EventTrigger EventName="KeyDown">
            <i:InvokeCommandAction Command="{Binding UserInputCommand}"
                                   PassEventArgsToCommand="True" />
        </i:EventTrigger>
    </i:Interaction.Triggers>
    <Grid>
        <Image HorizontalAlignment="Stretch"
               VerticalAlignment="Stretch"
               Stretch="Fill"
               RenderTransformOrigin="0.5,0.5"
               Source="../Resources/hockeyRinkGray.png">
            <i:Interaction.Triggers>
                <i:DataTrigger Binding="{Binding IsReverse}"
                               Value="True">
                    <i:ChangePropertyAction PropertyName="RenderTransform"
                                            Value="{StaticResource Mirror}" />
                </i:DataTrigger>
                <i:DataTrigger Binding="{Binding IsReverse}"
                               Value="False">
                    <i:ChangePropertyAction PropertyName="RenderTransform"
                                            Value="{StaticResource Normal}" />
                </i:DataTrigger>
            </i:Interaction.Triggers>
        </Image>
        <Border Padding="16">
            <Grid HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="2*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="3*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="64" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <Label Content="Game Clock"
                       Grid.Row="0"
                       Grid.ColumnSpan="2"
                       Style="{StaticResource MediumLabel}">
                    <i:Interaction.Triggers>
                        <i:DataTrigger Binding="{Binding IsSuddenDeath}"
                                       Value="True">
                            <i:ChangePropertyAction PropertyName="Visibility"
                                                    Value="hidden" />
                        </i:DataTrigger>
                        <i:DataTrigger Binding="{Binding IsSuddenDeath}"
                                       Value="False">
                            <i:ChangePropertyAction PropertyName="Visibility"
                                                    Value="visible" />
                        </i:DataTrigger>
                    </i:Interaction.Triggers>
                </Label>
                <Label Grid.Row="1"
                       Grid.ColumnSpan="2"
                       Width="500"
                       HorizontalAlignment="Center"
                       Style="{StaticResource LargeLabel}">
                    <Binding Path="GameClock">
                        <Binding.Converter>
                            <h:TimeSpanConverter />
                        </Binding.Converter>
                    </Binding>
                    <i:Interaction.Triggers>
                        <i:DataTrigger Binding="{Binding IsSuddenDeath}"
                                       Value="True">
                            <i:ChangePropertyAction PropertyName="Visibility"
                                                    Value="hidden" />
                        </i:DataTrigger>
                        <i:DataTrigger Binding="{Binding IsSuddenDeath}"
                                       Value="False">
                            <i:ChangePropertyAction PropertyName="Visibility"
                                                    Value="visible" />
                        </i:DataTrigger>
                        <i:DataTrigger Binding="{Binding ClockWithinThirtySeconds}"
                                       Value="True">
                            <i:ChangePropertyAction PropertyName="Background"
                                                    Value="#f4943d" />
                        </i:DataTrigger>
                        <i:DataTrigger Binding="{Binding ClockWithinMinute}"
                                       Value="True">
                            <i:ChangePropertyAction PropertyName="Background"
                                                    Value="#f4f36a" />
                        </i:DataTrigger>
                        <i:DataTrigger Binding="{Binding DefaultClock}"
                                       Value="True">
                            <i:ChangePropertyAction PropertyName="Background"
                                                    Value="White" />
                        </i:DataTrigger>
                    </i:Interaction.Triggers>
                </Label>
                <Label Content="SUDDEN DEATH!"
                       Grid.Row="1"
                       Grid.ColumnSpan="2"
                       HorizontalAlignment="Stretch"
                       Margin="96 0"
                       FontSize="128"
                       FontWeight="Bold"
                       HorizontalContentAlignment="Center"
                       VerticalContentAlignment="Center"
                       Foreground="OrangeRed"
                       FontFamily="Garamond">
                    <i:Interaction.Triggers>
                        <i:DataTrigger Binding="{Binding IsSuddenDeath}"
                                       Value="False">
                            <i:ChangePropertyAction PropertyName="Visibility"
                                                    Value="hidden" />
                        </i:DataTrigger>
                        <i:DataTrigger Binding="{Binding IsSuddenDeath}"
                                       Value="True">
                            <i:ChangePropertyAction PropertyName="Visibility"
                                                    Value="visible" />
                        </i:DataTrigger>
                    </i:Interaction.Triggers>
                </Label>
                <Label Content="{Binding HomeTeam}"
                       Grid.Row="2"
                       Grid.Column="0"
                       Style="{StaticResource MediumLabel}" />
                <Label Content="{Binding HomeScore}"
                       Grid.Row="3"
                       Grid.Column="0"
                       Width="300"
                       FontSize="200"
                       Margin="0 8 8 8"
                       Background="{Binding HomeColor}"
                       Style="{StaticResource LargeLabel}">
                </Label>
                <Label Content="{Binding VisitorTeam}"
                       Grid.Row="2"
                       Grid.Column="1"
                       Style="{StaticResource MediumLabel}" />
                <Label Content="{Binding VisitorScore}"
                       Grid.Row="3"
                       Grid.Column="1"
                       Width="300"
                       FontSize="200"
                       VerticalContentAlignment="Center"
                       Background="{Binding VisitorColor}"
                       Margin="8 8 0 8"
                       Style="{StaticResource LargeLabel}">
                </Label>
                <Grid HorizontalAlignment="Center"
                      Grid.Row="4"
                      Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Label Content="Penalties"
                           Grid.Row="0"
                           Style="{StaticResource SmallLabel}" />
                    <StackPanel Grid.Row="1"
                                Orientation="Horizontal">
                        <StackPanel Orientation="Horizontal"
                                    Margin="16 0">
                            <Ellipse Width="20"
                                     Height="20"
                                     Margin="24 0"
                                     HorizontalAlignment="Center">
                                <i:Interaction.Triggers>
                                    <i:DataTrigger Binding="{Binding ActiveHomePenaltyOne}"
                                                   Value="False">
                                        <i:ChangePropertyAction PropertyName="Visibility"
                                                                Value="Hidden" />
                                    </i:DataTrigger>
                                    <i:DataTrigger Binding="{Binding ActiveHomePenaltyOne}"
                                                   Value="True">
                                        <i:ChangePropertyAction PropertyName="Visibility"
                                                                Value="Visible" />
                                    </i:DataTrigger>
                                    <i:DataTrigger Binding="{Binding IsHighTick}"
                                                   Value="False">
                                        <i:ChangePropertyAction PropertyName="Fill"
                                                                Value="#ff9292" />
                                    </i:DataTrigger>
                                    <i:DataTrigger Binding="{Binding IsHighTick}"
                                                   Value="True">
                                        <i:ChangePropertyAction PropertyName="Fill"
                                                                Value="Red" />
                                    </i:DataTrigger>
                                </i:Interaction.Triggers>
                            </Ellipse>
                            <Label Style="{StaticResource ListLabel}"
                                   Width="150"
                                   Height="50">
                                <Binding Path="HomePenaltyOne">
                                    <Binding.Converter>
                                        <h:TimeSpanConverter />
                                    </Binding.Converter>
                                </Binding>
                            </Label>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Label Style="{StaticResource ListLabel}"
                                   Width="150"
                                   Height="50">
                                <Binding Path="HomePenaltyTwo">
                                    <Binding.Converter>
                                        <h:TimeSpanConverter />
                                    </Binding.Converter>
                                </Binding>
                            </Label>
                            <Ellipse Width="20"
                                     Height="20"
                                     Margin="24 0"
                                     HorizontalAlignment="Center">
                                <i:Interaction.Triggers>
                                    <i:DataTrigger Binding="{Binding ActiveHomePenaltyTwo}"
                                                   Value="False">
                                        <i:ChangePropertyAction PropertyName="Visibility"
                                                                Value="Hidden" />
                                    </i:DataTrigger>
                                    <i:DataTrigger Binding="{Binding ActiveHomePenaltyTwo}"
                                                   Value="True">
                                        <i:ChangePropertyAction PropertyName="Visibility"
                                                                Value="Visible" />
                                    </i:DataTrigger>
                                    <i:DataTrigger Binding="{Binding IsHighTick}"
                                                   Value="False">
                                        <i:ChangePropertyAction PropertyName="Fill"
                                                                Value="#ff9292" />
                                    </i:DataTrigger>
                                    <i:DataTrigger Binding="{Binding IsHighTick}"
                                                   Value="True">
                                        <i:ChangePropertyAction PropertyName="Fill"
                                                                Value="Red" />
                                    </i:DataTrigger>
                                </i:Interaction.Triggers>
                            </Ellipse>
                        </StackPanel>
                    </StackPanel>
                </Grid>
                <Grid HorizontalAlignment="Center"
                      Grid.Row="4"
                      Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Label Content="Penalties"
                           Grid.Row="0"
                           Style="{StaticResource SmallLabel}" />
                    <StackPanel Grid.Row="1"
                                Orientation="Horizontal">
                        <StackPanel Orientation="Horizontal"
                                    Margin="16 0">
                            <Ellipse Width="20"
                                     Height="20"
                                     Margin="24 0"
                                     HorizontalAlignment="Center">
                                <i:Interaction.Triggers>
                                    <i:DataTrigger Binding="{Binding ActiveVisitorPenaltyOne}"
                                                   Value="False">
                                        <i:ChangePropertyAction PropertyName="Visibility"
                                                                Value="Hidden" />
                                    </i:DataTrigger>
                                    <i:DataTrigger Binding="{Binding ActiveVisitorPenaltyOne}"
                                                   Value="True">
                                        <i:ChangePropertyAction PropertyName="Visibility"
                                                                Value="Visible" />
                                    </i:DataTrigger>
                                    <i:DataTrigger Binding="{Binding IsHighTick}"
                                                   Value="False">
                                        <i:ChangePropertyAction PropertyName="Fill"
                                                                Value="#ff9292" />
                                    </i:DataTrigger>
                                    <i:DataTrigger Binding="{Binding IsHighTick}"
                                                   Value="True">
                                        <i:ChangePropertyAction PropertyName="Fill"
                                                                Value="Red" />
                                    </i:DataTrigger>
                                </i:Interaction.Triggers>
                            </Ellipse>
                            <Label Style="{StaticResource ListLabel}"
                                   Width="150"
                                   Height="50">
                                <Binding Path="VisitorPenaltyOne">
                                    <Binding.Converter>
                                        <h:TimeSpanConverter />
                                    </Binding.Converter>
                                </Binding>
                            </Label>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Label Style="{StaticResource ListLabel}"
                                   Width="150"
                                   Height="50">
                                <Binding Path="VisitorPenaltyTwo">
                                    <Binding.Converter>
                                        <h:TimeSpanConverter />
                                    </Binding.Converter>
                                </Binding>
                            </Label>
                            <Ellipse Width="20"
                                     Height="20"
                                     Margin="24 0"
                                     HorizontalAlignment="Center">
                                <i:Interaction.Triggers>
                                    <i:DataTrigger Binding="{Binding ActiveVisitorPenaltyTwo}"
                                                   Value="False">
                                        <i:ChangePropertyAction PropertyName="Visibility"
                                                                Value="Hidden" />
                                    </i:DataTrigger>
                                    <i:DataTrigger Binding="{Binding ActiveVisitorPenaltyTwo}"
                                                   Value="True">
                                        <i:ChangePropertyAction PropertyName="Visibility"
                                                                Value="Visible" />
                                    </i:DataTrigger>
                                    <i:DataTrigger Binding="{Binding IsHighTick}"
                                                   Value="False">
                                        <i:ChangePropertyAction PropertyName="Fill"
                                                                Value="#ff9292" />
                                    </i:DataTrigger>
                                    <i:DataTrigger Binding="{Binding IsHighTick}"
                                                   Value="True">
                                        <i:ChangePropertyAction PropertyName="Fill"
                                                                Value="Red" />
                                    </i:DataTrigger>
                                </i:Interaction.Triggers>
                            </Ellipse>
                        </StackPanel>
                    </StackPanel>
                </Grid>
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Bottom"
                            Grid.Row="5"
                            Grid.Column="1">
                    <Button Height="32"
                            Width="32"
                            Focusable="False"
                            Command="{Binding ShowConfigurationCommand}">
                        <Image Source="../Resources/gear-wide-connected.png" />
                    </Button>
                    <Button Height="32"
                            Width="32"
                            Focusable="False"
                            Command="{Binding SwapSidesCommand}">
                        <Grid>
                            <Image Source="../Resources/toggle2-on.png">
                                <i:Interaction.Triggers>
                                    <i:DataTrigger Binding="{Binding IsReverse}"
                                                   Value="True">
                                        <i:ChangePropertyAction PropertyName="Visibility"
                                                                Value="Visible" />
                                    </i:DataTrigger>
                                    <i:DataTrigger Binding="{Binding IsReverse}"
                                                   Value="False">
                                        <i:ChangePropertyAction PropertyName="Visibility"
                                                                Value="Hidden" />
                                    </i:DataTrigger>
                                </i:Interaction.Triggers>
                            </Image>
                            <Image Source="../Resources/toggle2-off.png">
                                <i:Interaction.Triggers>
                                    <i:DataTrigger Binding="{Binding IsReverse}"
                                                   Value="True">
                                        <i:ChangePropertyAction PropertyName="Visibility"
                                                                Value="Hidden" />
                                    </i:DataTrigger>
                                    <i:DataTrigger Binding="{Binding IsReverse}"
                                                   Value="False">
                                        <i:ChangePropertyAction PropertyName="Visibility"
                                                                Value="Visible" />
                                    </i:DataTrigger>
                                </i:Interaction.Triggers>
                            </Image>
                        </Grid>
                    </Button>
                </StackPanel>
            </Grid>
            <i:Interaction.Triggers>
                <i:DataTrigger Binding="{Binding GameDone}"
                               Value="False">
                    <i:ChangePropertyAction PropertyName="Visibility"
                                            Value="Visible" />
                </i:DataTrigger>
                <i:DataTrigger Binding="{Binding GameDone}"
                               Value="True">
                    <i:ChangePropertyAction PropertyName="Visibility"
                                            Value="Visible" />
                </i:DataTrigger>
            </i:Interaction.Triggers>
        </Border>
        <Border Background="#ecb09d"
                Opacity="0.6">
            <i:Interaction.Triggers>
                <i:DataTrigger Binding="{Binding GameDone}"
                               Value="False">
                    <i:ChangePropertyAction PropertyName="Visibility"
                                            Value="Collapsed" />
                </i:DataTrigger>
                <i:DataTrigger Binding="{Binding GameDone}"
                               Value="True">
                    <i:ChangePropertyAction PropertyName="Visibility"
                                            Value="Visible" />
                </i:DataTrigger>
            </i:Interaction.Triggers>
            <TextBlock Text="Game Over"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontSize="128">
            </TextBlock>
        </Border>
    </Grid>
</Window>
